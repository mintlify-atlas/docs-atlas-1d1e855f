  "keyFeatures": [
    "Visual Page Builder with drag-and-drop block editing",
    "Multi-role access control: editors, administrators, developers",
    "Built-in DataTables framework with Spring REST integration",
    "E-commerce module with orders, delivery methods, and payments",
    "Multi-step form builder with email verification and SPAM protection",
    "Multi-language and multi-domain (MultiWeb) support",
    "Comprehensive application store with 60+ built-in apps",
    "Full-text search with Lucene indexing",
    "Audit logging and security hardening for enterprise use",
    "Spring Framework 7 with Spring Data JPA backend"
  ],
